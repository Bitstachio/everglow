# Application
NODE_ENV=development
PORT=3000

# Database
# Password special chars must be URL-encoded
#
# Local PostgreSQL (native install, default port):
DATABASE_URL="postgresql://everglow_dev:everglow_pass@localhost:5432/everglow_db"
#
# Docker Compose DB from the host (npm run start:dev outside Docker):
# default POSTGRES_HOST_PORT is 5433 to avoid clashing with a native
# Postgres on 5432 — see docker-compose.yml
# DATABASE_URL="postgresql://everglow_dev:everglow_pass@localhost:5433/everglow_db"

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name

# Encryption (for photos)
ENCRYPTION_MASTER_KEY=your-32-byte-master-encryption-key-change-in-production
AWS_KMS_KEY_ID=your-kms-key-id-optional

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/webp

# ---------------------------------------------------------------------------
# Docker Compose (optional overrides — defaults work out of the box)
# Copy this file to .env before running: docker compose up --build
#
# POSTGRES_DB=everglow_db
# POSTGRES_USER=everglow_dev
# POSTGRES_PASSWORD=everglow_pass
# POSTGRES_HOST_PORT=5433
# API_HOST_PORT=3000
#
# docker compose up: the api service overrides DATABASE_URL to use
# hostname "db" (not localhost). Auth0, AWS, and encryption vars
# above are still read from .env.
