  "info": {
    "title": "Everglow API",
    "description": "Photo-sharing platform for events — HTTP API contract (OpenAPI 3)",
    "version": "2.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "JWT access token"
      }
    },
    "schemas": {
      "UserDetailsResponseDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "email",
          "name",
          "createdAt",
          "updatedAt"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "isOnboarded": {
            "type": "boolean"
          },
          "details": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/UserDetailsResponseDto"
              }
            ]
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "isOnboarded",
          "details",
          "createdAt",
          "updatedAt"
        ]
      },
      "ResponseMetaDto": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "example": "2026-06-03T12:00:00.000Z"
          },
          "path": {
            "type": "string",
            "example": "/api/v2/auth/signin"
          }
        },
        "required": [
          "timestamp",
          "path"
        ]
      },
      "CreateUserDetailsDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {}
      },
      "EventResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "date": {
            "format": "date-time",
            "type": "string"
          },
          "creatorId": {
            "type": "string",
            "format": "uuid"
          },
          "invitationUrl": {
            "type": "string",
            "description": "Shareable invitation link composed from the stored invite token"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "date",
          "creatorId",
          "invitationUrl",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateEventDto": {
        "type": "object",
        "properties": {}
      },
      "JoinEventDto": {
        "type": "object",
        "properties": {
          "invitationUrl": {
            "type": "string",
            "description": "Full invitation URL or invite token",
            "example": "https://events.everglow.app/invite/aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
          }
        },
        "required": [
          "invitationUrl"
        ]
      },
      "UpdateEventDto": {
        "type": "object",
        "properties": {}
      },
      "AccessLevel": {
        "type": "string",
        "enum": [
          "ORGANIZER",
          "PARTICIPANT",
          "VIEWER"
        ]
      },
      "EventParticipantResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "accessLevel": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AccessLevel"
              }
            ]
          }
        },
        "required": [
          "userId",
          "name",
          "accessLevel"
        ]
      },
      "UpdateParticipantAccessDto": {
        "type": "object",
        "properties": {
          "accessLevel": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AccessLevel"
              }
            ]
          }
        },
        "required": [
          "accessLevel"
        ]
      },
      "GalleryResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "eventId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "maxLength": 100
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "eventId",
          "name",
          "createdAt",
          "updatedAt"
        ]
      },
      "UploadSlotResponseDto": {
        "type": "object",
        "properties": {
          "photoId": {
            "type": "string",
            "format": "uuid"
          },
          "uploadUrl": {
            "type": "string",
            "maxLength": 2048,
            "description": "Presigned S3 PUT URL the client uploads bytes to"
          }
        },
        "required": [
          "photoId",
          "uploadUrl"
        ]
      },
      "UploadFileDto": {
        "type": "object",
        "properties": {
          "contentType": {
            "type": "string",
            "enum": [
              "image/jpeg",
              "image/png",
              "image/webp",
              "image/heic",
              "image/heif"
            ],
            "example": "image/jpeg"
          },
          "sizeBytes": {
            "type": "number",
            "minimum": 1,
            "maximum": 26214400,
            "example": 1048576
          }
        },
        "required": [
          "contentType",
          "sizeBytes"
        ]
      },
      "CreateUploadUrlsDto": {
        "type": "object",
        "properties": {
          "files": {
            "maxItems": 20,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UploadFileDto"
            }
          }
        },
        "required": [
          "files"
        ]
      }
    }
  }
}
