          "email",
          "name",
          "createdAt",
          "updatedAt"
        ]
      },
      "ResponseMetaDto": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "example": "2026-06-03T12:00:00.000Z"
          },
          "path": {
            "type": "string",
            "example": "/api/v2/auth/signin"
          }
        },
        "required": [
          "timestamp",
          "path"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {}
      }
    }
  }
