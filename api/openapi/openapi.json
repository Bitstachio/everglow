            "type": "string",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
