# Backend API URL
# For local development:
# - iOS Simulator: http://localhost:3000
# - Android Emulator: http://10.0.2.2:3000
# - Physical device: http://YOUR_LOCAL_IP:3000 (e.g., http://192.168.1.100:3000)
# For production: https://your-api-domain.com
# NOTE: do NOT include the /api/v2 prefix here; the API client adds it.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Auth0 (mobile native app)
# Create a "Native" application in the Auth0 dashboard and copy its values here.
# AUDIENCE must equal the API Identifier configured in Auth0 and the
# AUTH0_AUDIENCE set in api/.env, otherwise the API will reject the token.
EXPO_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=your-native-app-client-id
EXPO_PUBLIC_AUTH0_AUDIENCE=https://your-api-identifier

# Auth0 dashboard config for this app (Native application settings):
# Allowed Callback URLs and Allowed Logout URLs must include:
#   everglowmobile://YOUR_DOMAIN/ios/com.anonymous.everglow-mobile/callback
#   everglowmobile://YOUR_DOMAIN/android/com.anonymous.everglowmobile/callback
# Enable "Allow Offline Access" on the API so refresh tokens are issued.
